//MERGE SORT program

#include <stdio.h>

// Merge function
void merge(int a[], int left, int mid, int right) {
    int i, j, k;
    int n1 = mid - left + 1;
    int n2 = right - mid;

    int L[n1], R[n2];

    // Copy data
    for(i = 0; i < n1; i++)
        L[i] = a[left + i];
    for(j = 0; j < n2; j++)
        R[j] = a[mid + 1 + j];

    i = 0; j = 0; k = left;

    // Merge arrays
    while(i < n1 && j < n2) {
        if(L[i] <= R[j]) {
            a[k] = L[i];
            i++;
        } else {
            a[k] = R[j];
            j++;
        }
        k++;
    }

    // Remaining elements
    while(i < n1) {
        a[k] = L[i];
        i++; k++;
    }

    while(j < n2) {
        a[k] = R[j];
        j++; k++;
    }
}

// Merge Sort function
void mergeSort(int a[], int left, int right) {
    if(left < right) {
        int mid = (left + right) / 2;

        mergeSort(a, left, mid);
        mergeSort(a, mid + 1, right);

        merge(a, left, mid, right);
    }
}

// Main function
int main() {
    int a[] = {5, 2, 4, 1};
    int n = 4, i;

    mergeSort(a, 0, n - 1);

    printf("Sorted array:\n");
    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
